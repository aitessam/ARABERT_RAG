# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx   # reserved for future use

# ── LLM Settings ──────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.1

# ── Alternative providers (OpenAI-compatible) ─────────────────────────────────
# Groq (free, fast — console.groq.com):
#   OPENAI_API_KEY=gsk_...
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#
# Mistral (free tier — console.mistral.ai):
#   OPENAI_API_KEY=...
#   OPENAI_MODEL=mistral-small-latest
#   LLM_BASE_URL=https://api.mistral.ai/v1
LLM_BASE_URL=

# ── Embedding Model ───────────────────────────────────────────────────────────
# Requires "passage: " / "query: " prefixes — applied automatically by the code.
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── Storage ───────────────────────────────────────────────────────────────────
VECTOR_STORE_DIR=data/vector_store
RAW_DATA_DIR=data/raw

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP_TOKENS=60

# ── Hybrid Retrieval ──────────────────────────────────────────────────────────
TOP_K_DENSE=10
TOP_K_SPARSE=10
TOP_K_FINAL=5

# ── Qdrant Vector Database ────────────────────────────────────────────────────
# Download native binary: https://github.com/qdrant/qdrant/releases
# Run: ./qdrant.exe  (default port 6333)
QDRANT_URL=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=arabic_rag

# ── PDF Reader ────────────────────────────────────────────────────────────────
PDF_HEADER_MARGIN=0.08      # fraction of page height
PDF_FOOTER_MARGIN=0.08
PDF_REPEAT_THRESHOLD=3      # pages a block must appear on to be flagged as header/footer
